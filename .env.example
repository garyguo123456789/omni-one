# Omni-One Enterprise AI Platform Configuration
# ==================================================
# Copy this file to .env and fill in your actual values

# AI Model APIs (at least one required)
# Get Google Gemini key from: https://aistudio.google.com/app/apikeys
GOOGLE_API_KEY=your-google-gemini-api-key

# Optional: Additional AI providers
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/omni_one
REDIS_URL=redis://localhost:6379

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=false
HOST=0.0.0.0
PORT=5003

# Enterprise Features (enable/disable advanced capabilities)
ENABLE_ETHICAL_AI=true
ENABLE_QUANTUM_OPTIMIZATION=true
ENABLE_FEDERATED_LEARNING=true
ENABLE_MULTIMODAL_PROCESSING=true

# External Service Integrations (optional)
SLACK_BOT_TOKEN=your-slack-bot-token
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
SALESFORCE_USERNAME=your-salesforce-username
SALESFORCE_PASSWORD=your-salesforce-password
SALESFORCE_SECURITY_TOKEN=your-salesforce-security-token

# Monitoring & Logging (optional)
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=INFO

# Security (generate strong keys for production)
JWT_SECRET_KEY=your-jwt-secret-key
ENCRYPTION_KEY=your-encryption-key-32-chars

# Performance Tuning
MAX_WORKERS=4
CACHE_TTL=3600
REQUEST_TIMEOUT=30
